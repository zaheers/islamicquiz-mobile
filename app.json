{
  "expo": {
    "name": "Al Noor",
    "slug": "islamicquiz-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/app-icon-1024.png",
    "scheme": "islamicquizmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0F2E2E",
        "foregroundImage": "./assets/app-icon-1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/alnoor-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F2E2E",
          "dark": {
            "backgroundColor": "#0F2E2E"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "website": "https://www.islamicquiz.app/",
      "developerWebsite": "https://www.zaheerai.com/",
      "router": {},
      "eas": {
        "projectId": "d87e3223-ae84-4987-ab5d-7ad5a496f01d"
      }
    }
  }
}